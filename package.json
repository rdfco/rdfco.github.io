{
  "name": "gspa-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/verify-brand-safety.mjs",
    "preview": "vite preview",
    "check": "npm run build",
    "lint": "eslint . --max-warnings 0",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run architecture:validate && npm run check:native && npm run app:validate && npm run features:validate && npm run scenes:validate && npm run models:validate && npm run camera:validate && npm run materials:validate && npm run animations:validate && npm run three:validate && npm run content:validate && npm run assets:validate && npm run audit:runtime && npm run build && npm run check:bundle",
    "typecheck": "tsc --noEmit",
    "check:native": "node scripts/verify-native-boundaries.mjs",
    "audit:runtime": "node scripts/audit-runtime.mjs",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "migration:status": "node scripts/migration-dashboard.mjs",
    "assets:inspect": "node scripts/inspect-glb.mjs",
    "assets:validate": "node scripts/validate-asset-registry.mjs",
    "assets:inventory": "node scripts/generate-asset-inventory.mjs",
    "content:validate": "node scripts/validate-content-boundaries.mjs",
    "three:validate": "node scripts/validate-three-foundations.mjs",
    "app:validate": "node scripts/validate-app-boundaries.mjs",
    "features:validate": "node scripts/validate-feature-boundaries.mjs",
    "scenes:validate": "node scripts/validate-scene-boundaries.mjs",
    "models:validate": "node scripts/validate-model-boundaries.mjs",
    "camera:validate": "node scripts/validate-camera-boundaries.mjs",
    "materials:validate": "node scripts/validate-material-boundaries.mjs",
    "animations:validate": "node scripts/validate-animation-boundaries.mjs",
    "architecture:validate": "node scripts/validate-architecture.mjs",
    "browser:contract": "node scripts/verify-navigation.mjs && node scripts/browser-check.mjs",
    "shaders:extract": "node scripts/extract-shaders.mjs",
    "shaders:recover": "node scripts/recover-material-shaders.mjs",
    "visual:baseline": "node scripts/capture-baseline.mjs",
    "visual:compare": "node scripts/compare-baseline.mjs",
    "visual:contract": "npm run build && node scripts/capture-contract.mjs",
    "visual:native": "node scripts/capture-native-contract.mjs",
    "baseline:performance": "node scripts/capture-performance-baseline.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "gsap": "^3.13.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.18.1",
    "three": "^0.185.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "prettier": "^3.9.5",
    "puppeteer-core": "^25.3.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.0.4",
    "vitest": "^4.1.10"
  }
}
